---
import CopyEmailButton from '../components/CopyEmailButton';
import '../styles/global.css';
import { experience, mainProjects, profile, publications, secondaryProjects, stackGroups } from '../data/siteData';

const navItems = [
  { label: 'Home', href: '#home' },
  { label: 'Projects', href: '#projects' },
  { label: 'Publications', href: '#publications' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
];

const publicationYears = [...new Set(publications.map((publication) => publication.year))];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={profile.headline} />
    <meta property="og:title" content={`${profile.name} · ${profile.role}`} />
    <meta property="og:description" content={profile.headline} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/homepage_files/profile.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${profile.name} · ${profile.role}`} />
    <meta name="twitter:description" content={profile.headline} />
    <meta name="twitter:image" content="/homepage_files/profile.jpg" />
    <title>{profile.name} · {profile.role}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="shortcut icon" type="image/png" href="/homepage_files/favicon.png" />
    <link rel="apple-touch-icon" href="/homepage_files/profile.jpg" />
  </head>
  <body>
    <div class="min-h-screen overflow-hidden">
      <header class="fixed inset-x-0 top-0 z-50 px-4 py-4">
        <nav class="mx-auto flex max-w-6xl items-center justify-between rounded-full border border-white/10 bg-graphite/70 px-4 py-3 text-sm text-white shadow-soft backdrop-blur-xl">
          <a href="#home" class="font-display font-semibold tracking-tight">GB</a>
          <div class="hidden items-center gap-1 md:flex">
            {navItems.map((item) => (
              <a class="rounded-full px-4 py-2 text-white/75 transition hover:bg-white/10 hover:text-white" href={item.href}>{item.label}</a>
            ))}
          </div>
          <a class="rounded-full bg-white px-4 py-2 font-semibold text-graphite transition hover:bg-signal" href={profile.links.linkedin} target="_blank" rel="noreferrer">
            LinkedIn
          </a>
        </nav>
      </header>

      <main id="home">
        <section class="relative overflow-hidden bg-graphite px-4 pb-24 pt-32 text-white md:pb-28 md:pt-40">
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_15%_20%,rgba(125,211,252,0.14),transparent_20rem),radial-gradient(circle_at_75%_10%,rgba(255,255,255,0.06),transparent_24rem),linear-gradient(180deg,#0e1520_0%,#121a25_100%)]"></div>
          <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
            <div>
              <p class="mb-5 inline-flex rounded-full border border-white/15 px-4 py-2 text-sm font-medium text-white/75">
                {profile.location} · Audio AI · Machine Listening · MIR
              </p>
              <h1 class="max-w-4xl font-display text-5xl font-semibold leading-[0.95] tracking-tight text-white text-balance md:text-7xl">
                {profile.headline}
              </h1>
              <p class="mt-7 max-w-2xl text-lg leading-8 text-white/78 md:text-xl">
                {profile.heroIntro}
              </p>
              <div class="mt-9 flex flex-wrap gap-3">
                <a class="rounded-full bg-signal px-6 py-3 text-sm font-bold text-graphite transition hover:bg-white" href="#projects">View projects</a>
                <a class="rounded-full border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:border-white hover:bg-white/10" href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
                <a class="rounded-full border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:border-white hover:bg-white/10" href={`mailto:${profile.email}`}>Email me</a>
              </div>
            </div>

            <aside class="dark-card p-4 md:p-5">
              <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5">
                <img src="/homepage_files/profile.jpg" alt="Gabriel Bibbó" class="aspect-[4/5] w-full object-cover object-top" />
              </div>
              <div class="grid grid-cols-2 gap-3 pt-4 text-sm">
                <div class="rounded-2xl bg-white/10 p-4">
                  <div class="text-2xl font-bold">3+ yrs</div>
                  <div class="text-white/60">audio ML research engineering</div>
                </div>
                <div class="rounded-2xl bg-white/10 p-4">
                  <div class="text-2xl font-bold">13</div>
                  <div class="text-white/60">publications & works</div>
                </div>
                <div class="rounded-2xl bg-white/10 p-4">
                  <div class="text-2xl font-bold">EU</div>
                  <div class="text-white/60">work authorization</div>
                </div>
                <div class="rounded-2xl bg-white/10 p-4">
                  <div class="text-2xl font-bold">Audio</div>
                  <div class="text-white/60">AI · DSP · MIR</div>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section id="projects" class="px-4 py-24">
          <div class="mx-auto max-w-6xl">
            <p class="section-kicker">Projects</p>
            <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
              <h2 class="section-title max-w-3xl">Research systems, datasets, demos, and music technology tools.</h2>
              <p class="max-w-sm text-sm leading-6 text-ink/60">A mix of peer-reviewed research work, deployable prototypes, and independent technical projects.</p>
            </div>

            <div class="mt-12 grid gap-6">
              {mainProjects.map((project, index) => (
                <article class="card grid gap-6 p-5 md:grid-cols-[0.95fr_1.4fr] md:p-7">
                  <div class={`project-media ${project.imageFit === 'contain' ? 'project-media-contain' : 'project-media-cover'}`}>
                    {project.image ? (
                      <img src={project.image} alt={project.title} class="transition duration-500 hover:scale-[1.02]" />
                    ) : (
                      <div class="flex h-full min-h-64 items-end bg-[radial-gradient(circle_at_30%_20%,rgba(125,211,252,0.45),transparent_18rem),linear-gradient(135deg,#1c1f24,#3d332d)] p-6">
                        <span class="font-display text-3xl font-semibold text-white/90">0{index + 1}</span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-col justify-between gap-8 p-1 md:p-3">
                    <div>
                      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-clay">{project.eyebrow}</p>
                      <h3 class="font-display text-3xl font-semibold tracking-tight text-ink md:text-4xl">{project.title}</h3>
                      <p class="mt-5 text-base leading-8 text-ink/70">{project.description}</p>
                    </div>
                    <div>
                      <div class="mb-5 flex flex-wrap gap-2">
                        {project.tags.map((tag) => <span class="rounded-full bg-graphite/5 px-3 py-1 text-xs font-semibold text-ink/70">{tag}</span>)}
                      </div>
                      <div class="flex flex-wrap gap-3">
                        {project.links.map((link) => (
                          <a class="rounded-full bg-graphite px-4 py-2 text-sm font-semibold text-white transition hover:bg-clay" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                        ))}
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>

            <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {secondaryProjects.map((project) => (
                <article class="card overflow-hidden p-4">
                  {project.image ? (
                    <div class={`secondary-media ${project.imageFit === 'contain' ? 'secondary-media-contain' : 'secondary-media-cover'}`}><img src={project.image} alt={project.title} /></div>
                  ) : <div class="mb-5 h-40 rounded-[1.25rem] bg-[radial-gradient(circle_at_30%_20%,rgba(125,211,252,0.38),transparent_14rem),linear-gradient(135deg,#1c1f24,#685040)]"></div>}
                  <h3 class="font-display text-xl font-semibold text-ink">{project.title}</h3>
                  <p class="mt-3 text-sm leading-6 text-ink/65">{project.description}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.tags.map((tag) => <span class="rounded-full bg-graphite/5 px-3 py-1 text-[11px] font-semibold text-ink/65">{tag}</span>)}
                  </div>
                  {project.links.length > 0 && (
                    <div class="mt-5 flex flex-wrap gap-2">
                      {project.links.map((link) => <a class="rounded-full border border-black/10 px-3 py-2 text-sm font-semibold text-clay transition hover:border-clay hover:bg-clay hover:text-white" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>)}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="publications" class="px-4 py-24">
          <div class="mx-auto max-w-6xl">
            <p class="section-kicker">Research / Publications</p>
            <h2 class="section-title max-w-3xl">Publications and works, ordered by year.</h2>
            <div class="mt-12 space-y-10">
              {publicationYears.map((year) => (
                <section class="grid gap-5 md:grid-cols-[8rem_1fr]">
                  <h3 class="font-display text-3xl font-semibold text-clay">{year}</h3>
                  <div class="space-y-4">
                    {publications.filter((publication) => publication.year === year).map((publication) => (
                      <article class="rounded-3xl border border-black/10 bg-white/70 p-6">
                        <h4 class="font-display text-xl font-semibold text-ink">{publication.title}</h4>
                        <p class="mt-2 text-sm leading-6 text-ink/60">{publication.authors}</p>
                        <p class="mt-2 text-sm leading-6 text-ink/75"><em>{publication.venue}</em></p>
                        <div class="mt-4 flex flex-wrap gap-3">
                          {publication.links.map((link) => <a class="text-sm font-semibold text-clay hover:text-ink" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>)}
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </section>

        <section id="experience" class="px-4 py-24">
          <div class="mx-auto max-w-6xl">
            <p class="section-kicker">Experience</p>
            <h2 class="section-title max-w-3xl">Employment experience.</h2>
            <div class="mt-12 space-y-5">
              {experience.map((item) => (
                <article class="card grid gap-5 p-6 md:grid-cols-[11rem_5.5rem_1fr] md:items-start">
                  <div class="text-sm font-semibold text-clay">{item.period}</div>
                  <div class="org-logo">
                    <img src={item.logo} alt={item.logoAlt} class={item.logoFit === 'contain' ? 'h-10 w-10 object-contain' : 'h-10 w-10 object-cover'} />
                  </div>
                  <div>
                    <h3 class="font-display text-2xl font-semibold text-ink">{item.title}</h3>
                    <p class="mt-1 text-sm font-semibold text-ink/60">{item.org}</p>
                    <ul class="mt-5 space-y-3 text-sm leading-7 text-ink/70">
                      {item.bullets.map((bullet) => <li class="pl-4 before:mr-3 before:content-['•']">{bullet}</li>)}
                    </ul>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="stack" class="px-4 py-24">
          <div class="mx-auto max-w-6xl">
            <p class="section-kicker">Technical Stack</p>
            <h2 class="section-title max-w-3xl">Tools and methods used across research, software, audio, and deployment work.</h2>
            <div class="mt-12 grid gap-5 md:grid-cols-2">
              {stackGroups.map((group) => (
                <article class="card p-6">
                  <h3 class="font-display text-2xl font-semibold text-ink">{group.name}</h3>
                  <div class="mt-5 flex flex-wrap gap-2">
                    {group.items.map((item) => <span class="rounded-full bg-graphite/5 px-3 py-2 text-xs font-semibold text-ink/70">{item}</span>)}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="contact" class="px-4 py-24 text-white">
          <div class="mx-auto max-w-6xl rounded-[2.5rem] bg-graphite p-8 shadow-soft md:p-12">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.24em] text-signal">Contact</p>
            <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
              <div>
                <h2 class="font-display text-4xl font-semibold tracking-tight text-balance md:text-6xl">Get in touch.</h2>
                <p class="mt-6 max-w-2xl text-lg leading-8 text-white/70">{profile.availability}</p>
                <p class="mt-6 text-white/70"><span class="font-semibold text-white">Email:</span> {profile.email}</p>
              </div>
              <div class="flex flex-wrap gap-3 lg:justify-end">
                <a class="rounded-full bg-signal px-5 py-3 text-sm font-bold text-graphite transition hover:bg-white" href={`mailto:${profile.email}`}>Email me</a>
                <a class="rounded-full bg-white px-5 py-3 text-sm font-bold text-graphite transition hover:bg-signal" href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
                <CopyEmailButton email={profile.email} client:load />
              </div>
            </div>
            <div class="mt-10 flex flex-wrap gap-3 border-t border-white/10 pt-6">
              <a class="profile-link" href={profile.links.github} target="_blank" rel="noreferrer">GitHub</a>
              <a class="profile-link" href={profile.links.scholar} target="_blank" rel="noreferrer">Scholar</a>
              <a class="profile-link" href={profile.links.orcid} target="_blank" rel="noreferrer">ORCID</a>
            </div>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
