---
import ProfileAssistant from './ProfileAssistant';
import '../styles/global.css';
import { education, experience, mainProjects, profile, publications, secondaryProjects, stackGroups } from '../data/siteData';

const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const siteUrl = 'https://gbibbo-site.pages.dev';

const ui = {
  en: {
    nav: [
      { label: 'Home', href: '#home' },
      { label: 'Projects', href: '#projects' },
      { label: 'Publications', href: '#publications' },
      { label: 'Experience', href: '#experience' },
      { label: 'Contact', href: '#contact' },
    ],
    role: 'Audio AI Research Engineer',
    heroBio: 'I build audio machine learning systems that run outside the notebook, across sound event detection, voice activity detection, privacy-preserving audio, and music information retrieval. Four years writing embedded C/C++ for Bang & Olufsen taught me the distance between a prototype and a device that ships. I am also a DJ and producer, and most of my interest in how machines listen started from how I listen myself.',
    metaDescription: 'Audio AI research engineer working on machine listening, privacy-preserving audio, and embedded ML.',
    heroPill: 'Montevideo, Uruguay · Audio AI · Machine Listening · MIR',
    viewProjects: 'View projects',
    emailMe: 'Email me',
    stats: ['audio ML research engineering', 'publications & works', 'work authorization', 'AI · DSP · MIR'],
    statsValues: ['3+ yrs', '13', 'EU', 'Audio'],
    projectsKicker: 'Projects',
    projectsTitle: 'Research systems, datasets, demos, and music technology tools.',
    projectsIntro: 'Peer-reviewed work first, followed by independent systems and personal technical projects.',
    publicationsKicker: 'Research / Publications',
    publicationsTitle: 'Publications and works, ordered by year.',
    experienceKicker: 'Experience',
    experienceTitle: 'Employment experience.',
    educationKicker: 'Formal Education',
    educationTitle: 'Formal studies.',
    stackKicker: 'Technical Stack',
    stackTitle: 'Tools and methods used across research, software, audio, and deployment work.',
    additionalKicker: 'Additional Information',
    additionalTitle: 'Languages, certifications, memberships, and grants.',
    contactKicker: 'Contact',
    contactTitle: 'Get in touch.',
    emailLabel: 'Email:',
    contactAvailability: profile.availability,
    switchToSpanish: 'Switch to Spanish',
    switchToEnglish: 'Switch to English',
    openImage: 'Open image',
    closeImage: 'Close image',
    projectImage: 'Project image',
    languageSelector: 'Language selector',
  },
  es: {
    nav: [
      { label: 'Inicio', href: '#home' },
      { label: 'Proyectos', href: '#projects' },
      { label: 'Publicaciones', href: '#publications' },
      { label: 'Experiencia', href: '#experience' },
      { label: 'Contacto', href: '#contact' },
    ],
    role: 'Ingeniero de investigación en Audio AI',
    heroBio: 'Construyo sistemas de machine learning de audio que funcionan fuera del notebook, en detección de eventos sonoros, detección de actividad de voz, audio que preserva la privacidad y recuperación de información musical. Cuatro años escribiendo C/C++ embebido para productos de Bang & Olufsen me enseñaron la distancia entre un prototipo y un dispositivo que llega a producción. También soy DJ y productor, y buena parte de mi interés por cómo escuchan las máquinas nació de cómo escucho yo.',
    metaDescription: 'Ingeniero de investigación en Audio AI, trabajando en machine listening, audio que preserva la privacidad y ML embebido.',
    heroPill: 'Montevideo, Uruguay · Audio AI · Machine Listening · MIR',
    viewProjects: 'Ver proyectos',
    emailMe: 'Escribime',
    stats: ['investigación en audio ML', 'publicaciones y trabajos', 'autorización de trabajo', 'AI · DSP · MIR'],
    statsValues: ['3+ años', '13', 'UE', 'Audio'],
    projectsKicker: 'Proyectos',
    projectsTitle: 'Sistemas de investigación, datasets, demos y herramientas de tecnología musical.',
    projectsIntro: 'Primero el trabajo revisado por pares; después sistemas independientes y proyectos técnicos personales.',
    publicationsKicker: 'Investigación / Publicaciones',
    publicationsTitle: 'Publicaciones y trabajos, ordenados por año.',
    experienceKicker: 'Experiencia',
    experienceTitle: 'Experiencia laboral.',
    educationKicker: 'Formación académica',
    educationTitle: 'Estudios formales.',
    stackKicker: 'Stack técnico',
    stackTitle: 'Herramientas y métodos usados en investigación, software, audio y despliegue.',
    additionalKicker: 'Información adicional',
    additionalTitle: 'Idiomas, certificaciones, membresías y grants.',
    contactKicker: 'Contacto',
    contactTitle: 'Hablemos.',
    emailLabel: 'Email:',
    contactAvailability: 'Ciudadano italiano con autorización de trabajo en la UE. Abierto a roles remotos en LATAM/Europa y a oportunidades seleccionadas de relocalización dentro de la UE.',
    switchToSpanish: 'Cambiar a español',
    switchToEnglish: 'Cambiar a inglés',
    openImage: 'Abrir imagen',
    closeImage: 'Cerrar imagen',
    projectImage: 'Imagen del proyecto',
    languageSelector: 'Selector de idioma',
  },
}[lang];

const projectTranslations = {
  es: {
    'Audio-Language Models for Voice Activity Detection': {
      eyebrow: 'Audio AI · VAD · Evaluación de modelos',
      description: 'Esta investigación evalúa cómo los audio-language models detectan habla cuando el audio es corto, ruidoso, reverberante o filtrado. El proyecto compara Qwen2-Audio-7B, Qwen2-Audio-7B con LoRA, Qwen3-Omni-30B y Silero VAD sobre el mismo banco de pruebas degradadas. El mejor resultado fue Qwen2-Audio-7B con LoRA y OPRO-Template: 93,3% de balanced accuracy sobre 21.340 clips degradados.',
    },
    'Sounds of Home Dataset': {
      eyebrow: 'Dataset con privacidad · Audio doméstico',
      description: 'Sounds of Home es un dataset residencial para sound event detection. Contiene 1.344 grabaciones de una hora tomadas en 8 hogares de Bélgica, con grabadoras AudioMoth colocadas en salas de estar y cocinas. El habla fue removida antes de la publicación y se incluyeron predicciones de PANNs para los frames de audio.',
    },
    'Speech Removal Framework': {
      eyebrow: 'Privacidad · Remoción de habla · WASPAA',
      description: 'Framework para remover habla de grabaciones de audio antes de compartirlas o publicarlas. El sistema permite flujos de publicación de audio que preservan la privacidad, manteniendo información acústica no verbal útil para investigación en sound event detection.',
    },
    'Harmonic EDM Mixing Compatibility': {
      eyebrow: 'MIR · Mezcla armónica · Tesis MSc',
      description: 'Este sistema de análisis musical estima qué tan bien pueden mezclarse armónicamente dos tracks de EDM. Analiza tracks, calcula chroma features, los convierte en Tonal Interval Vectors, compara compatibilidad armónica y sugiere transposiciones que pueden mejorar una mezcla. El trabajo comenzó como tesis de MSc y luego se publicó en ICWE 2022.',
    },
    'ASR Enhancement Platform': {
      eyebrow: 'Speech enhancement · Plataforma backend',
      description: 'ASR Enhancement Platform compara dos caminos de reconocimiento de voz sobre el mismo audio: transcripción cruda y enhance-and-transcribe. El backend guarda jobs, archivos de audio, transcripciones y payloads de proveedores para poder inspeccionar cada resultado. Usa FastAPI, Celery, PostgreSQL, Redis, MinIO, Docker Compose, métricas, tracing, Grafana y CI.',
    },
    'Traktor ML': {
      eyebrow: 'MIR · Organización de librería DJ',
      description: 'Traktor ML convierte una librería local de Techno y Tech House en playlists listas para Traktor. El pipeline extrae embeddings MERT, separa stems con Demucs, lee BPM y tonalidad con Essentia, agrupa tracks similares, los ordena para transiciones más suaves y exporta playlists M3U. La corrida V4 procesó 239 tracks y exportó 14 playlists. La colección privada de audio no está incluida en el repositorio.',
    },
    ALPACA: {
      description: 'Plataforma de trading algorítmico en Python con ingesta de datos de mercado, controles de riesgo, backtesting y monitoreo en tiempo real.',
    },
    'Raspberry Pi Sound Event Recognition Demo': {
      description: 'Demo en Raspberry Pi para reconocimiento de eventos sonoros en tiempo real. El sistema ejecuta redes neuronales preentrenadas en un dispositivo edge de bajo costo, expone una interfaz web y puede enviar notificaciones por email cuando detecta eventos seleccionados de AudioSet.',
    },
    '3H-ATO': {
      description: 'Herramienta mecánica diseñada durante la pandemia para evitar tocar directamente superficies compartidas. Es un proyecto de prototipado físico, no un proyecto de AI.',
    },
    'Automatic IoT Soap Dispenser': {
      description: 'Dispositivo IoT de higiene de manos para entornos industriales. Usaba acero inoxidable, WiFi, conectividad cloud, sensores IR/RFID y un tanque de 3 litros.',
    },
    'UyVoy Mobile App': {
      description: 'Proyecto de app móvil para reservar turnos y reducir aglomeraciones durante la pandemia. Mi rol figura como Project Manager.',
    },
  },
};

const projectOverrides = {
  'Audio-Language Models for Voice Activity Detection': {
    description: 'This research evaluates how audio-language models detect speech when the audio is short, noisy, reverberant, or filtered. The project compares Qwen2-Audio-7B, Qwen2-Audio-7B with LoRA, Qwen3-Omni-30B, and Silero VAD on the same degraded test bank. The best result came from Qwen2-Audio-7B with LoRA and OPRO-Template: 93.3% balanced accuracy on 21,340 degraded clips.',
    image: '/homepage_files/Qwen_Overall_BA.png',
    imageFit: 'contain',
  },
  'Sounds of Home Dataset': {
    description: 'Sounds of Home is a residential audio dataset for sound event detection. It contains 1,344 one-hour recordings from 8 homes in Belgium, captured with AudioMoth recorders placed in living rooms and kitchens. Speech was removed before release, and PANNs predictions were provided for the audio frames.',
  },
  'Speech Removal Framework': {
    eyebrow: 'Privacy · Speech removal · WASPAA',
    description: 'A framework for removing speech from audio recordings before they are shared or published. The system supports privacy-preserving release workflows for audio datasets while retaining non-speech acoustic information for downstream sound event detection research.',
    image: '/homepage_files/speech_removal_framework.svg',
    imageFit: 'contain',
  },
  'Harmonic EDM Mixing Compatibility': {
    description: 'This music analysis system estimates how well two EDM tracks mix harmonically. It analyzes tracks, computes chroma features, converts them into Tonal Interval Vectors, compares harmonic compatibility, and suggests pitch shifts that can improve a mix. The work began as an MSc thesis and later became an ICWE 2022 publication.',
  },
  'ASR Enhancement Platform': {
    description: 'The ASR Enhancement Platform compares two speech recognition paths on the same audio: raw transcription and enhance-and-transcribe. The backend stores jobs, audio files, transcripts, and provider payloads so each result can be inspected later. It uses FastAPI, Celery, PostgreSQL, Redis, MinIO, Docker Compose, metrics, tracing, Grafana, and CI.',
  },
  'Traktor ML': {
    image: '/homepage_files/traktor_interface.svg',
    description: 'Traktor ML turns a local Techno and Tech House library into Traktor-ready playlists. The pipeline extracts MERT embeddings, separates stems with Demucs, reads BPM and key metadata with Essentia, clusters similar tracks, orders them for smoother transitions, and exports M3U playlists. The current V4 run processed 239 tracks and exported 14 playlists. The private audio collection is not included in the repo.',
  },
  ALPACA: {
    description: 'Python-based algorithmic trading platform with market data ingestion, risk controls, backtesting, and real-time monitoring.',
  },
};

const allProjects = [...mainProjects, ...secondaryProjects];
const projectByTitle = (title) => {
  const project = allProjects.find((item) => item.title === title);
  if (!project) return null;
  const translated = isEs ? projectTranslations.es[title] ?? {} : {};
  return { ...project, ...(projectOverrides[title] ?? {}), ...translated };
};

const featuredProjectTitles = [
  'Audio-Language Models for Voice Activity Detection',
  'Sounds of Home Dataset',
  'Speech Removal Framework',
  'Harmonic EDM Mixing Compatibility',
  'ASR Enhancement Platform',
  'Traktor ML',
];

const featuredProjects = featuredProjectTitles.map(projectByTitle).filter(Boolean);
const secondaryProjectList = secondaryProjects
  .filter((project) => !featuredProjectTitles.includes(project.title))
  .map((project) => ({ ...project, ...(projectOverrides[project.title] ?? {}), ...(isEs ? projectTranslations.es[project.title] ?? {} : {}) }));

const isContainImage = (project) => project.imageFit === 'contain';
const isSquareImage = (project) => project.title === 'ASR Enhancement Platform';
const imagePosition = (project) => project.imagePosition ?? (project.title === 'ASR Enhancement Platform' ? 'center 62%' : 'center center');

const companyMeta = (item) => {
  if (item.org.includes('University of Surrey')) return { logo: '/homepage_files/surrey.jpg', alt: 'University of Surrey logo', url: 'https://www.surrey.ac.uk/' };
  if (item.org.includes('Webhelp')) return { logo: '/homepage_files/logo-google.svg', alt: 'Google logo', url: 'https://workspace.google.com/' };
  if (item.org.includes('KPMG')) return { logo: '/homepage_files/logo-kpmg.svg', alt: 'KPMG logo', url: 'https://kpmg.com/es/es.html' };
  if (item.org.includes('Ikatu')) return { logo: '/homepage_files/logo-ikatu.svg', alt: 'Ikatu logo', url: 'https://www.ikatu.com/' };
  return { logo: item.logo, alt: item.logoAlt ?? item.org, url: '#' };
};

const tagTranslations = {
  Privacy: 'Privacidad',
  Datasets: 'Datasets',
  Dataset: 'Dataset',
  'Speech removal': 'Remoción de habla',
  Monitoring: 'Monitoreo',
  Sensors: 'Sensores',
  'Industrial hygiene': 'Higiene industrial',
  'Mobile app': 'App móvil',
  'Civic tech': 'Tecnología cívica',
  'Project management': 'Gestión de proyectos',
  'Product design': 'Diseño de producto',
  Prototyping: 'Prototipado',
  'Edge AI': 'AI edge',
  'Raspberry Pi': 'Raspberry Pi',
  'Physical prototyping': 'Prototipado físico',
  'Backtesting': 'Backtesting',
};
const localizeTag = (tag) => (isEs ? tagTranslations[tag] ?? tag : tag);

const localizePeriod = (period) => {
  if (!isEs) return period;
  return period.replaceAll('Dec.', 'Dic.').replaceAll('Apr.', 'Abr.').replace('Present', 'Presente');
};

const localizePlace = (text) => {
  if (!isEs) return text;
  return text.replaceAll('Spain', 'España').replaceAll('Remote', 'Remoto');
};

const additionalInfo = isEs ? [
  { title: 'Idiomas', items: ['Español — Nativo', 'Inglés — C1', 'Portugués — A2'] },
  { title: 'Certificaciones', items: ['PRINCE2 Foundation', 'Deep Learning Specialization', 'Machine Learning — Stanford / Coursera'] },
  { title: 'Música y membresías', items: ['Escuela de música: Virgilio Scarabelli Alberti', 'Miembro de IEEE Signal Processing Society'] },
  { title: 'Grants de investigación', items: ['Participante en EPSRC AI for Sound'] },
] : [
  { title: 'Languages', items: ['Spanish — Native', 'English — C1', 'Portuguese — A2'] },
  { title: 'Certifications', items: ['PRINCE2 Foundation', 'Deep Learning Specialization', 'Machine Learning — Stanford / Coursera'] },
  { title: 'Music and memberships', items: ['Music school: Virgilio Scarabelli Alberti', 'IEEE Signal Processing Society member'] },
  { title: 'Research grants', items: ['Participant in EPSRC AI for Sound'] },
];

const experienceTranslations = {
  es: {
    'Visiting Researcher (collaboration)': {
      title: 'Visiting Researcher (collaboration)',
      bullets: [
        'Preparación de un artículo para IEEE/ACM TASLP con Mark D. Plumbley y Simone Spagnol (Università Iuav di Venezia) sobre VAD con la familia Qwen-Audio bajo degradaciones psicoacústicas, usando PEFT/LoRA, optimización de prompts con OPRO, cuantización 4-bit NF4 y evaluación contra un baseline congelado de Qwen3-Omni.',
        'Coautoría de un artículo para IEEE Signal Processing Magazine con Arshdeep Singh (King’s College London) sobre audio que preserva la privacidad y machine listening.',
      ],
    },
    'Research Engineer in Sound Sensing': {
      title: 'Research Engineer in Sound Sensing',
      bullets: [
        'Desarrollo de sistemas end-to-end de audio ML para entornos inteligentes reales, cubriendo preparación de datos, evaluación de modelos, despliegue de prototipos, releases open-source, demos, datasets y documentación técnica para assisted living, smart buildings y monitoreo de sonido urbano.',
        'Construcción de pipelines de SED con preservación de privacidad para grabaciones sensibles en hogares, incluyendo un dataset residencial de 197 GB, workflows de remoción de habla y recursos reproducibles de evaluación.',
        'Diseño de pipelines VAD basados en Slurm para comparar 8 modelos bajo degradaciones acústicas controladas, con análisis de robustez y comparación estadística entre familias de modelos.',
        'Despliegue de inferencia CNN en tiempo real en Raspberry Pi, incluyendo cuantización, perfilado térmico, evaluación de consumo y documentación de edge sound sensing.',
        'Publicación y presentación de investigación en IEEE WASPAA, CHiME Workshop, ICWE, Inter-Noise, SMC, UKAI, UKIS y AES. Supervisión de proyectos de grado y máster.',
      ],
    },
    'Technical Support Engineer - Google Workspace': {
      title: 'Technical Support Engineer - Google Workspace',
      bullets: ['Soporte Tier 3 para clientes enterprise de Google Workspace en APIs, OAuth, SAML/SSO, IAM, aprovisionamiento de usuarios, migración de datos, configuración DNS/dominios y ajustes de seguridad/compliance.'],
    },
    'IT Auditor': {
      title: 'IT Auditor',
      bullets: ['Soporte a empresas de telecomunicaciones y departamentos de IT en servicios de auditoría.'],
    },
    'R&D Engineer': {
      title: 'R&D Engineer',
      bullets: [
        'Diseño y entrega de firmware de audio e IoT en C/C++ embebido para productos de automatización del hogar de Bang & Olufsen: drivers de bajo nivel, integración de hardware, audio I/O y conectividad a Internet.',
        'Trabajo sobre el ciclo de vida del producto: requerimientos, arquitectura, implementación, testing, validación y documentación orientada a cliente.',
        'Capacitación e incorporación de nuevos programadores en prácticas de desarrollo embebido.',
      ],
    },
  },
};

const educationTranslations = {
  es: {
    'MSc Sound and Music Computing': {
      degree: 'MSc Sound and Music Computing',
      details: 'Tesis de máster sobre compatibilidad armónica para mezcla EDM. Calificación final de tesis: 9/10.',
    },
    'BSc Electrical Engineering': {
      degree: 'BSc Electrical Engineering',
      details: 'Tesis de grado sobre robots móviles autónomos comunicados mediante software-defined radio.',
    },
  },
};

const stackTranslations = {
  es: {
    Stack: 'Stack',
    ML: 'ML',
    Audio: 'Audio',
    Practice: 'Práctica',
    'Supervised and Self-supervised Learning': 'Aprendizaje supervisado y self-supervised',
    'Evaluation Pipelines': 'Pipelines de evaluación',
    'Statistical Testing': 'Testing estadístico',
    'Edge Deployment': 'Despliegue edge',
    'Sound Event Detection': 'Detección de eventos sonoros',
    'Voice Activity Detection': 'Detección de actividad de voz',
    'Music Information Retrieval': 'Recuperación de información musical',
    'Digital Signal Processing': 'Procesamiento digital de señales',
    'Real-Time Audio': 'Audio en tiempo real',
    'Electronic Music Production': 'Producción de música electrónica',
    'Reproducible ML pipelines': 'Pipelines ML reproducibles',
    'Dataset Curation': 'Curaduría de datasets',
    'Open-Source Development': 'Desarrollo open-source',
    'MLOps practices': 'Prácticas MLOps',
    'AI-assisted Development': 'Desarrollo asistido por AI',
    'Technical Writing': 'Escritura técnica',
    'Interdisciplinary Collaboration': 'Colaboración interdisciplinaria',
  },
};

const translatedExperience = experience.map((item) => ({ ...item, ...(isEs ? experienceTranslations.es[item.title] ?? {} : {}) }));
const translatedEducation = education.map((item) => ({ ...item, ...(isEs ? educationTranslations.es[item.degree] ?? {} : {}) }));
const translatedStackGroups = stackGroups.map((group) => ({
  ...group,
  name: isEs ? stackTranslations.es[group.name] ?? group.name : group.name,
  items: group.items.map((item) => (isEs ? stackTranslations.es[item] ?? item : item)),
}));

const correctedPublications = publications.map((publication) => {
  if (publication.title === 'A New Compatibility Measure for Harmonic EDM Mixing') return { ...publication, authors: 'Gabriel Bibbó; Ángel Faraldo' };
  if (publication.title === 'Towards a New Compatibility Measure for Harmonic EDM Mixing') return { ...publication, venue: isEs ? 'Tesis de máster, Universitat Pompeu Fabra, Barcelona, España, 2021. Tutor: Ángel Faraldo.' : 'Master thesis, Universitat Pompeu Fabra, Barcelona, Spain, 2021. Supervisor: Ángel Faraldo.' };
  if (publication.title === 'Autonomous Mobile Robots Comunicated by Software Defined Radio') return { ...publication, authors: 'Gabriel Bibbó; Mariana Gelós; Martín Randall; Pablo Belzarena; Federico Larroca', venue: isEs ? 'Tesis de grado, Universidad de la República, Montevideo, Uruguay, 2017.' : publication.venue };
  return publication;
});
const publicationYears = [...new Set(correctedPublications.map((publication) => publication.year))];

const linkLabel = (label) => {
  if (!isEs) return label;
  return ({
    Code: 'Código', Paper: 'Artículo', Link: 'Enlace', Identifier: 'Identificador', Repository: 'Repositorio', Publication: 'Publicación', 'Official site': 'Sitio oficial', 'Dataset site': 'Sitio del dataset', 'AES program': 'Programa AES', Demo: 'Demo', DOI: 'DOI', Video: 'Video', ISBN: 'ISBN', Preprint: 'Preprint',
  })[label] ?? label;
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={ui.metaDescription} />
    <meta property="og:title" content={`${profile.name} · ${ui.role}`} />
    <meta property="og:description" content={ui.metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/homepage_files/profile.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${profile.name} · ${ui.role}`} />
    <meta name="twitter:description" content={ui.metaDescription} />
    <meta name="twitter:image" content="/homepage_files/profile.jpg" />
    <title>{profile.name} · {ui.role}</title>
    <link rel="alternate" hreflang="en" href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="es" href={`${siteUrl}/es/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="shortcut icon" type="image/png" href="/homepage_files/favicon.png" />
    <link rel="apple-touch-icon" href="/homepage_files/profile.jpg" />
  </head>
  <body>
    <div class="min-h-screen overflow-hidden">
      <header class="fixed inset-x-0 top-0 z-50 px-4 py-4">
        <nav class="mx-auto flex max-w-6xl items-center justify-between rounded-full border border-white/10 bg-graphite/70 px-4 py-3 text-sm text-white shadow-soft backdrop-blur-xl">
          <a href={isEs ? '/es/#home' : '#home'} class="font-display font-semibold tracking-tight">GB</a>
          <div class="hidden items-center gap-1 md:flex">
            {ui.nav.map((item) => <a class="rounded-full px-4 py-2 text-white/75 transition hover:bg-white/10 hover:text-white" href={item.href}>{item.label}</a>)}
          </div>
          <div class="flex items-center gap-2">
            <div class="language-switcher" aria-label={ui.languageSelector}>
              <a data-language-link="en" aria-label={ui.switchToEnglish} class={`language-pill ${!isEs ? 'language-pill-active' : ''}`} href="/">🇬🇧 EN</a>
              <a data-language-link="es" aria-label={ui.switchToSpanish} class={`language-pill ${isEs ? 'language-pill-active' : ''}`} href="/es/">🇪🇸 ES</a>
            </div>
            <a class="rounded-full bg-white px-4 py-2 font-semibold text-graphite transition hover:bg-signal" href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          </div>
        </nav>
      </header>

      <main id="home">
        <section class="relative overflow-hidden bg-graphite px-4 pb-24 pt-32 text-white md:pb-28 md:pt-40">
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_15%_20%,rgba(125,211,252,0.14),transparent_20rem),radial-gradient(circle_at_75%_10%,rgba(255,255,255,0.06),transparent_24rem),linear-gradient(180deg,#0e1520_0%,#121a25_100%)]"></div>
          <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
            <div>
              <p class="mb-5 inline-flex rounded-full border border-white/15 px-4 py-2 text-sm font-medium text-white/80">{ui.heroPill}</p>
              <h1 class="max-w-4xl font-display text-6xl font-semibold leading-[0.9] tracking-tight text-white text-balance md:text-8xl">{profile.name}</h1>
              <p class="mt-5 font-display text-2xl font-semibold tracking-tight text-signal md:text-4xl">{ui.role}</p>
              <p class="mt-7 max-w-2xl text-lg leading-8 text-white/78 md:text-xl">{ui.heroBio}</p>
              <div class="mt-9 flex flex-wrap gap-3">
                <a class="rounded-full bg-signal px-6 py-3 text-sm font-bold text-graphite transition hover:bg-white" href="#projects">{ui.viewProjects}</a>
                <a class="rounded-full border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:border-white hover:bg-white/10" href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
                <a class="rounded-full border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:border-white hover:bg-white/10" href={`mailto:${profile.email}`}>{ui.emailMe}</a>
              </div>
            </div>
            <aside class="dark-card p-4 md:p-5">
              <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5">
                <img src="/homepage_files/profile.jpg" alt="Gabriel Bibbó" class="aspect-[4/5] w-full object-cover object-top" />
              </div>
              <div class="grid grid-cols-2 gap-3 pt-4 text-sm">
                {ui.stats.map((stat, index) => <div class="rounded-2xl bg-white/10 p-4"><div class="text-2xl font-bold">{ui.statsValues[index]}</div><div class="text-white/60">{stat}</div></div>)}
              </div>
            </aside>
          </div>
        </section>

        <section id="projects" class="px-4 py-24">
          <div class="mx-auto max-w-6xl">
            <p class="section-kicker">{ui.projectsKicker}</p>
            <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
              <h2 class="section-title max-w-3xl">{ui.projectsTitle}</h2>
              <p class="max-w-sm text-sm leading-6 text-ink/60">{ui.projectsIntro}</p>
            </div>
            <div class="mt-12 grid gap-6">
              {featuredProjects.map((project, index) => (
                <article class="card grid gap-6 p-5 md:grid-cols-[0.95fr_1.4fr] md:p-7">
                  <button type="button" class={`project-media image-lightbox-trigger ${isContainImage(project) ? 'project-media-contain' : 'project-media-cover'} ${isSquareImage(project) ? 'project-media-square' : ''}`} data-lightbox-src={project.image} data-lightbox-alt={project.title} aria-label={`${ui.openImage}: ${project.title}`}>
                    {project.image ? <img src={project.image} alt={project.title} style={`object-position: ${imagePosition(project)};`} class="transition duration-500 hover:scale-[1.02]" /> : <div class="flex h-full min-h-64 items-end bg-[radial-gradient(circle_at_30%_20%,rgba(125,211,252,0.45),transparent_18rem),linear-gradient(135deg,#1c1f24,#3d332d)] p-6"><span class="font-display text-3xl font-semibold text-white/90">0{index + 1}</span></div>}
                  </button>
                  <div class="flex flex-col justify-between gap-8 p-1 md:p-3"><div><div class="mb-3 flex flex-wrap items-center gap-3"><p class="text-sm font-semibold uppercase tracking-[0.2em] text-clay">{project.eyebrow}</p><span class="project-year-badge">{project.year}</span></div><h3 class="font-display text-3xl font-semibold tracking-tight text-ink md:text-4xl">{project.title}</h3><p class="mt-5 text-base leading-8 text-ink/70">{project.description}</p></div><div><div class="mb-5 flex flex-wrap gap-3">{project.tags.map((tag) => <span class="rounded-full bg-graphite/5 px-3 py-1 text-xs font-semibold text-ink/75">{localizeTag(tag)}</span>)}</div><div class="flex flex-wrap gap-3">{project.links.map((link) => <a class="rounded-full bg-graphite px-4 py-2 text-sm font-semibold text-white transition hover:bg-clay" href={link.href} target="_blank" rel="noreferrer">{linkLabel(link.label)}</a>)}</div></div></div>
                </article>
              ))}
            </div>
            <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {secondaryProjectList.map((project) => (
                <article class="card overflow-hidden p-4">
                  {project.image ? <button type="button" class={`secondary-media image-lightbox-trigger ${isContainImage(project) ? 'secondary-media-contain' : 'secondary-media-cover'}`} data-lightbox-src={project.image} data-lightbox-alt={project.title} aria-label={`${ui.openImage}: ${project.title}`}><img src={project.image} alt={project.title} style={`object-position: ${imagePosition(project)};`} /></button> : <div class="mb-5 h-40 rounded-[1.25rem] bg-[radial-gradient(circle_at_30%_20%,rgba(125,211,252,0.38),transparent_14rem),linear-gradient(135deg,#1c1f24,#685040)]"></div>}
                  <div class="mb-3 flex items-center justify-between gap-3"><h3 class="font-display text-xl font-semibold text-ink">{project.title}</h3><span class="project-year-badge shrink-0">{project.year}</span></div><p class="mt-3 text-sm leading-6 text-ink/65">{project.description}</p><div class="mt-4 flex flex-wrap gap-3">{project.tags.map((tag) => <span class="rounded-full bg-graphite/5 px-3 py-1 text-[11px] font-semibold text-ink/70">{localizeTag(tag)}</span>)}</div>{project.links.length > 0 && <div class="mt-5 flex flex-wrap gap-2">{project.links.map((link) => <a class="rounded-full border border-black/10 px-3 py-2 text-sm font-semibold text-clay transition hover:border-clay hover:bg-clay hover:text-white" href={link.href} target="_blank" rel="noreferrer">{linkLabel(link.label)}</a>)}</div>}
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="publications" class="px-4 py-24"><div class="mx-auto max-w-6xl"><p class="section-kicker">{ui.publicationsKicker}</p><h2 class="section-title max-w-3xl">{ui.publicationsTitle}</h2><div class="mt-12 space-y-10">{publicationYears.map((year) => <section class="grid gap-5 md:grid-cols-[8rem_1fr]"><h3 class="font-display text-3xl font-semibold text-clay">{year}</h3><div class="space-y-4">{correctedPublications.filter((publication) => publication.year === year).map((publication) => <article class="rounded-3xl border border-black/10 bg-white/70 p-6"><h4 class="font-display text-xl font-semibold text-ink">{publication.title}</h4><p class="mt-2 text-sm leading-6 text-ink/60">{publication.authors}</p><p class="mt-2 text-sm leading-6 text-ink/75"><em>{publication.venue}</em></p><div class="mt-4 flex flex-wrap gap-3">{publication.links.map((link) => <a class="text-sm font-semibold text-clay hover:text-ink" href={link.href} target="_blank" rel="noreferrer">{linkLabel(link.label)}</a>)}</div></article>)}</div></section>)}</div></div></section>

        <section id="experience" class="px-4 py-24"><div class="mx-auto max-w-6xl"><p class="section-kicker">{ui.experienceKicker}</p><h2 class="section-title max-w-3xl">{ui.experienceTitle}</h2><div class="mt-12 space-y-5">{translatedExperience.map((item) => { const company = companyMeta(item); return <article class="card grid gap-5 p-6 md:grid-cols-[11rem_1fr] md:items-start"><div class="experience-side"><div class="text-sm font-semibold text-clay">{localizePeriod(item.period)}</div><a class="experience-logo-link" href={company.url} target="_blank" rel="noreferrer" aria-label={`Visit ${item.org}`}><img src={company.logo} alt={company.alt} class={`experience-logo-contain ${item.org.includes('Ikatu') ? 'experience-logo-ikatu' : ''}`} /></a></div><div><h3 class="font-display text-2xl font-semibold text-ink">{item.title}</h3><p class="mt-1 text-sm font-semibold text-ink/60">{localizePlace(item.org)}</p><ul class="mt-5 space-y-3 text-sm leading-7 text-ink/70">{item.bullets.map((bullet) => <li class="pl-4 before:mr-3 before:content-['•']">{bullet}</li>)}</ul></div></article>; })}</div></div></section>

        <section id="education" class="px-4 py-24"><div class="mx-auto max-w-6xl"><p class="section-kicker">{ui.educationKicker}</p><h2 class="section-title max-w-3xl">{ui.educationTitle}</h2><div class="mt-12 grid gap-5 md:grid-cols-2">{translatedEducation.map((item) => <article class="card p-7"><p class="text-sm font-semibold text-clay">{item.period}</p><h3 class="mt-4 font-display text-2xl font-semibold text-ink">{item.degree}</h3><p class="mt-2 text-sm font-semibold text-ink/60">{localizePlace(item.institution)}</p><p class="mt-5 text-sm leading-7 text-ink/70">{item.details}</p></article>)}</div></div></section>

        <section id="stack" class="px-4 py-24"><div class="mx-auto max-w-6xl"><p class="section-kicker">{ui.stackKicker}</p><h2 class="section-title max-w-3xl">{ui.stackTitle}</h2><div class="mt-12 grid gap-6 md:grid-cols-2">{translatedStackGroups.map((group) => <article class="card p-6"><h3 class="font-display text-2xl font-semibold text-ink">{group.name}</h3><div class="stack-chip-grid mt-6">{group.items.map((item) => <span class="stack-chip">{item}</span>)}</div></article>)}</div></div></section>

        <section id="additional" class="px-4 py-24"><div class="mx-auto max-w-6xl"><p class="section-kicker">{ui.additionalKicker}</p><h2 class="section-title max-w-3xl">{ui.additionalTitle}</h2><div class="mt-12 grid gap-5 md:grid-cols-2">{additionalInfo.map((group) => <article class="card p-6"><h3 class="font-display text-2xl font-semibold text-ink">{group.title}</h3><div class="stack-chip-grid mt-5">{group.items.map((item) => <span class="stack-chip">{item}</span>)}</div></article>)}</div></div></section>

        <section id="contact" class="px-4 py-24 text-white"><div class="mx-auto max-w-6xl rounded-[2.5rem] bg-graphite p-8 shadow-soft md:p-12"><p class="mb-4 text-sm font-semibold uppercase tracking-[0.24em] text-signal">{ui.contactKicker}</p><div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end"><div><h2 class="font-display text-4xl font-semibold tracking-tight text-balance md:text-6xl">{ui.contactTitle}</h2><p class="mt-6 max-w-2xl text-lg leading-8 text-white/70">{ui.contactAvailability}</p><p class="mt-6 text-white/70"><span class="font-semibold text-white">{ui.emailLabel}</span> {profile.email}</p></div><div class="flex flex-wrap gap-3 lg:justify-end"><a class="rounded-full bg-signal px-5 py-3 text-sm font-bold text-graphite transition hover:bg-white" href={`mailto:${profile.email}`}>{ui.emailMe}</a><a class="rounded-full bg-white px-5 py-3 text-sm font-bold text-graphite transition hover:bg-signal" href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a></div></div><div class="mt-10 flex flex-wrap gap-3 border-t border-white/10 pt-6"><a class="profile-link" href={profile.links.github} target="_blank" rel="noreferrer">GitHub</a><a class="profile-link" href={profile.links.scholar} target="_blank" rel="noreferrer">Scholar</a><a class="profile-link" href={profile.links.orcid} target="_blank" rel="noreferrer">ORCID</a></div></div></section>

        <div id="image-lightbox" class="image-lightbox" hidden aria-hidden="true"><button type="button" class="image-lightbox-backdrop" aria-label={ui.closeImage}></button><div class="image-lightbox-shell"><button type="button" class="image-lightbox-close" aria-label={ui.closeImage}>×</button><div id="image-lightbox-frame" class="image-lightbox-frame"></div></div></div>
        <script define:vars={{ lang, projectImage: ui.projectImage }}>
          if (location.pathname === '/' && localStorage.getItem('preferredLanguage') === 'es') location.replace('/es/' + location.hash);
          document.querySelectorAll('[data-language-link]').forEach((link) => link.addEventListener('click', (event) => { localStorage.setItem('preferredLanguage', link.dataset.languageLink); if (location.hash) { event.preventDefault(); const base = link.getAttribute('href') || '/'; location.href = base.replace(/#.*$/, '') + location.hash; } }));
          const lightbox = document.getElementById('image-lightbox');
          const frame = document.getElementById('image-lightbox-frame');
          const closeButtons = lightbox?.querySelectorAll('.image-lightbox-close, .image-lightbox-backdrop') ?? [];
          const closeLightbox = () => { if (!lightbox || !frame) return; frame.innerHTML = ''; lightbox.hidden = true; lightbox.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; };
          document.querySelectorAll('.image-lightbox-trigger').forEach((btn) => btn.addEventListener('click', () => { if (!lightbox || !frame) return; const src = btn.dataset.lightboxSrc; if (!src) return; const img = document.createElement('img'); img.src = src; img.alt = btn.dataset.lightboxAlt || projectImage; img.className = 'image-lightbox-img'; frame.replaceChildren(img); lightbox.hidden = false; lightbox.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }));
          closeButtons.forEach((button) => button.addEventListener('click', closeLightbox));
          document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && lightbox && !lightbox.hidden) closeLightbox(); });
        </script>
      </main>
      <ProfileAssistant client:load />
    </div>
  </body>
</html>
